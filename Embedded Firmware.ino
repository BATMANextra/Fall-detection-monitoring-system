// ============================================================
//  Utilities
// ============================================================
float compute_smv(float ax, float ay, float az) {
    return sqrtf(ax*ax + ay*ay + az*az);
}

void reset_voting() {
    for (int i = 0; i < 5; i++) prob_ring[i] = 0.0f;
    prob_idx = 0;
}

// ------------------------------------------------------------
//  Debounced button read
// ------------------------------------------------------------
bool isCancelButtonPressed() {
    if (digitalRead(BUTTON_PIN) == LOW) {
        if (millis() - last_button_press > BUTTON_DEBOUNCE_MS) {
            last_button_press = millis();
            return true;
        }
    }
    return false;
}

// ============================================================
//  Complementary filter orientation
// ============================================================
void update_orientation(float ax, float ay, float az,
                        float gx, float gy, float gz) {
    float pitch_gyro = cf_pitch + gy * DT;
    float roll_gyro  = cf_roll  + gx * DT;
    float pitch_acc  = atan2f(ax, sqrtf(ay*ay + az*az)) * (180.0f / M_PI);
    float roll_acc   = atan2f(ay, sqrtf(ax*ax + az*az)) * (180.0f / M_PI);
    cf_pitch = CF_ALPHA * pitch_gyro + (1.0f - CF_ALPHA) * pitch_acc;
    cf_roll  = CF_ALPHA * roll_gyro  + (1.0f - CF_ALPHA) * roll_acc;
}

// ============================================================
//  Wi-Fi and Telegram functions (unchanged)
// ============================================================
bool connectWiFi(unsigned long timeout_ms = 10000UL) {
    if (WiFi.status() == WL_CONNECTED) return true;
    Serial.print("Wi-Fi connecting");
    WiFi.mode(WIFI_STA);
    WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
    unsigned long start = millis();
    while (WiFi.status() != WL_CONNECTED) {
        if (millis() - start > timeout_ms) {
            Serial.println(" TIMEOUT – notification unavailable.");
            WiFi.disconnect(true);
            return false;
        }
        delay(300);
        Serial.print(".");
    }
    Serial.print(" OK. IP: ");
    Serial.println(WiFi.localIP());
    return true;
}

void sendTelegramAlert(float peak_g, float orient_deg) {
    if (last_notif_ms != 0 && millis() - last_notif_ms < NOTIF_CD) {
        Serial.println("Notification skipped – cooldown active.");
        return;
    }
    if (!connectWiFi(8000UL)) {
        Serial.println("Notification FAILED – no Wi-Fi.");
        return;
    }
    unsigned long total_s = millis() / 1000;
    unsigned long mins    = total_s / 60;
    unsigned long secs    = total_s % 60;
    String msg = String("%F0%9F%9A%A8+FALL+DETECTED%0A")
               + "Time+since+boot:+" + String(mins) + "min+" + String(secs) + "s%0A"
               + "Peak+impact:+" + String(peak_g, 2) + "g%0A"
               + "Orientation+change:+" + String(orient_deg, 1) + "%C2%B0%0A"
               + "FallGuard+is+alerting+for+help.+Please+check+on+the+person.";
    String url = String("https://api.telegram.org/bot")
               + TG_BOT_TOKEN
               + "/sendMessage?chat_id="
               + TG_CHAT_ID
               + "&text=" + msg;
    HTTPClient http;
    http.begin(url);
    http.setTimeout(8000);
    int code = http.GET();
    http.end();
    if (code == 200) {
        Serial.println("Telegram notification sent.");
        last_notif_ms = millis();
    } else {
        Serial.print("Telegram notification FAILED. HTTP code: ");
        Serial.println(code);
    }
    WiFi.disconnect(true);
}

